# Copy to backend/.env and frontend/.env (or a root .env) and adjust as needed.
# Never commit a real .env — only this example with placeholder values is tracked.

# ---- Backend ----
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://quatrace:quatrace@localhost:5432/quatrace
# Separate database used by the API test suite (created by docker-compose init).
TEST_DATABASE_URL=postgresql://quatrace:quatrace@localhost:5432/quatrace_test
JWT_SECRET=change-this-in-production
JWT_REFRESH_SECRET=change-this-in-production
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=info

# ---- Frontend ----
VITE_API_URL=http://localhost:3000/api
